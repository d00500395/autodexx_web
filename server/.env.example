# Required API keys
TAVILY_API_KEY=replace_me

# Optional: LLM review endpoint (defaults shown)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:latest
OLLAMA_TIMEOUT_SECONDS=120

# Tavily result count
TAVILY_RESULTS=8

# Keep this disabled for headful mode.
# Set to 1 only when you intentionally want true headless browser mode.
ALLOW_HEADLESS_BROWSER_DOMAINS=0

# Browser channel selection:
# - chromium: use Playwright-managed Chromium (recommended for servers)
# - chrome: use system Chrome if installed
PLAYWRIGHT_BROWSER_CHANNEL=chromium

# If set to 1/true/yes/on, fail instead of falling back from channel.
REQUIRE_BROWSER_CHANNEL=0
